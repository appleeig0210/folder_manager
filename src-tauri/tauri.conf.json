{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PeopleFolderManager",
  "version": "2.0.0",
  "identifier": "com.peoplefoldermanager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "人物資料夾管理器",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset:; connect-src 'self' asset: http://127.0.0.1:8765 http://localhost:8765 ws://127.0.0.1:8765 ws://localhost:8765; img-src 'self' asset: http://127.0.0.1:8765 http://localhost:8765 http://asset.localhost data: blob:; media-src 'self' asset: http://127.0.0.1:8765 http://localhost:8765 http://asset.localhost blob:; style-src 'self' 'unsafe-inline' asset:; script-src 'self' 'unsafe-inline' asset:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$HOME/**",
            "$DESKTOP/**",
            "$DOWNLOAD/**",
            "$DOCUMENT/**",
            "$VIDEO/**",
            "$DATA/**",
            "C:/**",
            "D:/**",
            "E:/**",
            "F:/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "externalBin": ["bin/api-server"]
  }
}
